package com.mycompany.hospitalsystem;

import javax.swing.*;
import javax.swing.table.DefaultTableModel;
import java.awt.*;
import java.sql.*;

public class PatientFrame extends JFrame {
    JLabel ssnLbl = new JLabel("Patient SSN:");
    JTextField ssnField = new JTextField();
    
    JLabel nameLbl = new JLabel("Name:");
    JTextField nameField = new JTextField();
    
    JLabel insLbl = new JLabel("Medical Insurance (1/0):");
    JTextField insField = new JTextField();
    
    JLabel admitLbl = new JLabel("Date Admitted (YYYY-MM-DD):");
    JTextField admitField = new JTextField();
    
    JLabel outLbl = new JLabel("Date Checked Out:");
    JTextField outField = new JTextField();

    JButton addBtn = new JButton("Add");
    JButton updateBtn = new JButton("Update");
    JButton deleteBtn = new JButton("Delete");
    JButton searchBtn = new JButton("Search");
    JButton showAllBtn = new JButton("Show All");
    JButton backBtn = new JButton("Back");

    DefaultTableModel tableModel;
    JTable table;

    String dbURL = "jdbc:sqlserver://localhost:1433;databaseName=Hospital;user=sa;password=1234;encrypt=true;trustServerCertificate=true;";

    public PatientFrame() {
        setTitle("Patient management");
        setLayout(null);
        setBounds(300, 50, 650, 650);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);

        ssnLbl.setBounds(20, 20, 150, 30); ssnField.setBounds(200, 20, 150, 30);
        nameLbl.setBounds(20, 60, 150, 30); nameField.setBounds(200, 60, 150, 30);
        insLbl.setBounds(20, 100, 150, 30); insField.setBounds(200, 100, 150, 30);
        admitLbl.setBounds(20, 140, 180, 30); admitField.setBounds(200, 140, 150, 30);
        outLbl.setBounds(20, 180, 180, 30); outField.setBounds(200, 180, 150, 30);

        add(ssnLbl); add(ssnField);
        add(nameLbl); add(nameField);
        add(insLbl); add(insField);
        add(admitLbl); add(admitField);
        add(outLbl); add(outField);

        addBtn.setBounds(20, 230, 80, 30);
        updateBtn.setBounds(110, 230, 80, 30);
        deleteBtn.setBounds(200, 230, 80, 30);
        searchBtn.setBounds(290, 230, 80, 30);
        showAllBtn.setBounds(380, 230, 100, 30);
        backBtn.setBounds(490, 230, 80, 30);

        add(addBtn); add(updateBtn); add(deleteBtn); add(searchBtn); add(showAllBtn); add(backBtn);

        String[] columns = {"P_ssn", "Name", "Insurance", "Admitted", "Checked Out"};
        tableModel = new DefaultTableModel(columns, 0);
        table = new JTable(tableModel);
        JScrollPane sp = new JScrollPane(table);
        sp.setBounds(20, 280, 600, 300);
        add(sp);


        // 1. Add 
        addBtn.addActionListener(e -> {
            try (Connection conn = DriverManager.getConnection(dbURL)) {
                String sql = "INSERT INTO Patients (P_ssn, name, medicalInsurance, dateAdmitted, dateCheckedOut) VALUES (?, ?, ?, ?, ?)";
                PreparedStatement pst = conn.prepareStatement(sql);
                pst.setInt(1, Integer.parseInt(ssnField.getText()));
                pst.setString(2, nameField.getText());
                pst.setBoolean(3, insField.getText().equals("1")); 
                pst.setDate(4, Date.valueOf(admitField.getText())); 
                
                if(outField.getText().isEmpty()) {
                    pst.setNull(5, java.sql.Types.DATE);
                } else {
                    pst.setDate(5, Date.valueOf(outField.getText()));
                }
                
                pst.executeUpdate();
                JOptionPane.showMessageDialog(null, "Added successfully");
                clearFields();
            } catch (Exception ex) { JOptionPane.showMessageDialog(null, "Error: " + ex.getMessage()); }
        });

        // 2. Update
        updateBtn.addActionListener(e -> {
            try (Connection conn = DriverManager.getConnection(dbURL)) {
                String sql = "UPDATE Patients SET name=?, medicalInsurance=?, dateAdmitted=?, dateCheckedOut=? WHERE P_ssn=?";
                PreparedStatement pst = conn.prepareStatement(sql);
                pst.setString(1, nameField.getText());
                pst.setBoolean(2, insField.getText().equals("1"));
                pst.setDate(3, Date.valueOf(admitField.getText()));
                
                if(outField.getText().isEmpty()) {
                    pst.setNull(4, java.sql.Types.DATE);
                } else {
                    pst.setDate(4, Date.valueOf(outField.getText()));
                }
                
                pst.setInt(5, Integer.parseInt(ssnField.getText()));
                pst.executeUpdate();
                JOptionPane.showMessageDialog(null, "Edited successfully");
                clearFields();
            } catch (Exception ex) { JOptionPane.showMessageDialog(null, "Error: " + ex.getMessage()); }
        });

        // 3. Delete
        deleteBtn.addActionListener(e -> {
            try (Connection conn = DriverManager.getConnection(dbURL)) {
                String sql = "DELETE FROM Patients WHERE P_ssn=?";
                PreparedStatement pst = conn.prepareStatement(sql);
                pst.setInt(1, Integer.parseInt(ssnField.getText()));
                pst.executeUpdate();
                JOptionPane.showMessageDialog(null, "Successfully deleted");
                clearFields();
            } catch (Exception ex) { JOptionPane.showMessageDialog(null, "Error: " + ex.getMessage()); }
        });

        // 4. Search
        searchBtn.addActionListener(e -> {
            try (Connection conn = DriverManager.getConnection(dbURL)) {
                String sql = "SELECT * FROM Patients WHERE P_ssn=?";
                PreparedStatement pst = conn.prepareStatement(sql);
                pst.setInt(1, Integer.parseInt(ssnField.getText()));
                ResultSet rs = pst.executeQuery();
                if (rs.next()) {
                    nameField.setText(rs.getString("name"));
                    insField.setText(rs.getBoolean("medicalInsurance") ? "1" : "0");
                    admitField.setText(rs.getDate("dateAdmitted").toString());
                    
                    Date outDate = rs.getDate("dateCheckedOut");
                    outField.setText(outDate != null ? outDate.toString() : "");
                } else {
                    JOptionPane.showMessageDialog(null, "The patient is not present!");
                }
            } catch (Exception ex) { JOptionPane.showMessageDialog(null, "Error: " + ex.getMessage()); }
        });

        // 5. Show All
        showAllBtn.addActionListener(e -> {
            try (Connection conn = DriverManager.getConnection(dbURL)) {
                String sql = "SELECT * FROM Patients";
                Statement st = conn.createStatement();
                ResultSet rs = st.executeQuery(sql);
                tableModel.setRowCount(0); 
                while (rs.next()) {
                    tableModel.addRow(new Object[]{
                        rs.getInt("P_ssn"), 
                        rs.getString("name"), 
                        rs.getBoolean("medicalInsurance") ? "Yes" : "No",
                        rs.getDate("dateAdmitted"),
                        rs.getDate("dateCheckedOut")
                    });
                }
            } catch (Exception ex) { JOptionPane.showMessageDialog(null, "Error: " + ex.getMessage()); }
        });

        // Back
        backBtn.addActionListener(e -> {
            new MainFrame().setVisible(true);
            dispose();
        });
    }

    private void clearFields() {
        ssnField.setText("");
        nameField.setText("");
        insField.setText("");
        admitField.setText("");
        outField.setText("");
    }
}
